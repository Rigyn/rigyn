{
  "name": "@rigyn/kernel",
  "version": "0.5.1",
  "private": true,
  "description": "Reusable agent loop, durable session primitives, and execution environment for rigyn",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rigyn/rigyn.git",
    "directory": "packages/kernel"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.public-types.json",
    "test": "node --import tsx --test --experimental-test-isolation=none test/**/*.test.ts",
    "check": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "MIT",
  "dependencies": {
    "@rigyn/models": "0.5.1",
    "ignore": "7.0.6",
    "typebox": "1.1.38",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  }
}
