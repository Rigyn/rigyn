{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rigyn/rigyn/blob/main/benchmarks/runtime-performance-report.schema.json",
  "title": "Rigyn runtime performance report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "suite",
    "purpose",
    "deterministicFixtures",
    "samplesPerScenario",
    "environment",
    "scenarios",
    "summary"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "suite": { "const": "runtime-performance-v1" },
    "purpose": { "const": "runtime-regression-guard" },
    "deterministicFixtures": { "const": true },
    "samplesPerScenario": { "type": "integer", "minimum": 1, "maximum": 10 },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "architecture", "node"],
      "properties": {
        "platform": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "node": { "type": "string", "minLength": 1 }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 11,
      "items": { "$ref": "#/$defs/scenario" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarios", "passed"],
      "properties": {
        "scenarios": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "operation",
        "fixture",
        "samplesMs",
        "minimumMs",
        "medianMs",
        "p95Ms",
        "maximumMs",
        "ceilingMs",
        "passed"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "operation": { "enum": ["startup", "reload", "resume", "rpc-replay", "event-page"] },
        "fixture": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "extensionCount": { "type": "integer", "minimum": 0 },
            "runtimeEntryCount": { "type": "integer", "minimum": 0 },
            "commandCount": { "type": "integer", "minimum": 0 },
            "eventCount": { "type": "integer", "minimum": 0 },
            "pageLimit": { "type": "integer", "minimum": 1 },
            "branchCount": { "type": "integer", "minimum": 1 },
            "toolProgressCount": { "type": "integer", "minimum": 0 },
            "cold": { "type": "boolean" },
            "materializedRowBudget": { "type": "integer", "minimum": 1 }
          }
        },
        "samplesMs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number", "minimum": 0 }
        },
        "minimumMs": { "type": "number", "minimum": 0 },
        "medianMs": { "type": "number", "minimum": 0 },
        "p95Ms": { "type": "number", "minimum": 0 },
        "maximumMs": { "type": "number", "minimum": 0 },
        "ceilingMs": { "type": "number", "exclusiveMinimum": 0 },
        "passed": { "type": "boolean" }
      }
    }
  }
}
