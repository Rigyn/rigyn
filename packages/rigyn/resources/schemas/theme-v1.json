{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rigyn:schema:theme:v1",
  "title": "Rigyn theme",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "styles"],
  "properties": {
    "$schema": { "type": "string", "maxLength": 4096 },
    "schemaVersion": { "const": 1 },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,62}$",
      "not": { "enum": ["dark", "light", "mono"] }
    },
    "base": { "enum": ["dark", "light"] },
    "vars": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "integer", "minimum": 0, "maximum": 255 },
          { "type": "string", "pattern": "^(#[0-9A-Fa-f]{6}|\\$[A-Za-z][A-Za-z0-9_.-]{0,62})$" },
          { "const": "" }
        ]
      }
    },
    "styles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^(title|muted|accent|info|link|code|border|editor|editorActive|working|user|assistant|success|warning|error|selection|userMessage|toolPending|toolRunning|toolSuccess|toolError)$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "foreground": { "$ref": "#/$defs/foreground" },
            "background": { "$ref": "#/$defs/background" },
            "bold": { "type": "boolean" },
            "italic": { "type": "boolean" }
          }
        }
      }
    }
  },
  "$defs": {
    "foreground": {
      "anyOf": [
        { "type": "integer", "minimum": 0, "maximum": 255 },
        { "type": "string", "pattern": "^(#[0-9A-Fa-f]{6}|\\$[A-Za-z][A-Za-z0-9_.-]{0,62})$" },
        { "const": "" }
      ]
    },
    "background": {
      "anyOf": [
        { "type": "integer", "minimum": 0, "maximum": 255 },
        { "type": "string", "pattern": "^(#[0-9A-Fa-f]{6}|\\$[A-Za-z][A-Za-z0-9_.-]{0,62})$" }
      ]
    }
  }
}
