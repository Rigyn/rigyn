{
  "name": "@rigyn/terminal",
  "version": "0.5.1",
  "private": true,
  "description": "Raw terminal UI engine for rigyn applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "native/**/*",
    "scripts/*.mjs",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rigyn/rigyn.git",
    "directory": "packages/terminal"
  },
  "keywords": [
    "tui",
    "terminal",
    "text-editor",
    "differential-rendering",
    "typescript"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "check": "npm run typecheck && npm test && npm run native:verify",
    "native:build": "node scripts/build-native.mjs",
    "native:verify": "node scripts/verify-native.mjs"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "MIT",
  "dependencies": {
    "get-east-asian-width": "1.6.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "7.0.2"
  }
}
