  // Explicit model metadata for endpoints without model discovery.
  // "models": [
  //   {
  //     "provider": "company",
  //     "id": "code-model",
  //     "displayName": "Company Code Model",
  //     "description": "Internal coding model",
  //     "contextTokens": 131072,
  //     "maxOutputTokens": 16384,
  //     "tools": true,
  //     "reasoning": true,
  //     "images": false,
  //     "reasoningEfforts": ["off", "minimal", "low", "medium", "high", "xhigh", "max"],
  //     // Non-secret, exact-model headers. Authentication headers are rejected.
  //     "headers": { "x-tenant": "engineering" },
  //     // Provider values; null removes that level from selection.
  //     "reasoningEffortMap": { "minimal": null, "low": "lite", "high": "intense" },
  //     "requestCompatibility": {
  //       "supportsUsageInStreaming": true,
  //       "maxTokensField": "max_completion_tokens", // Or "max_tokens".
  //       "supportsReasoningEffort": true,
  //       "reasoningFormat": "chat-template", // openai, openrouter, deepseek, together, zai, qwen, qwen-chat-template, chat-template, string-thinking, or ant-ling.
  //       "chatTemplateParameters": {
  //         "enable_thinking": { "$var": "thinking.enabled" },
  //         "reasoning_level": { "$var": "thinking.effort", "omitWhenOff": true }
  //       },
  //       "cacheControlFormat": "anthropic",
  //       "cacheControlTtl": "1h", // 5m or 1h.
  //       "sendSessionAffinityHeaders": true,
  //       "sessionAffinityFormat": "openai-nosession", // openai, openai-nosession, or openrouter.
  //       // Use one routing dialect, never both.
  //       "openRouterRouting": { "only": ["first-party"], "allow_fallbacks": false }
  //       // "vercelGatewayRouting": { "only": ["bedrock"], "order": ["bedrock", "anthropic"] }
