  //   "llama.cpp": {
  //     "kind": "llama-router",
  //     "id": "llama.cpp",
  //     "baseUrl": "http://127.0.0.1:8080",
  //     "timeoutMs": 15000
  //   },
  //   "company-gateway": {
  //     "kind": "gateway-messages",
  //     "gatewayUrl": "https://gateway.example.com/v1", // GET /config discovers the credential-scoped endpoint and models.
  //     "credentialProvider": "company-gateway",
